{
  "name": "@factorize/app",
  "private": true,
  "license": "ISC",
  "workspaces": {
    "packages": [
      "packages/*",
      "clients/js"
    ],
    "nohoist": [
      "@factorize/program-tests/**",
      "@factorize/program-tests/**/**"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "yarn workspace @factorize/sdk build && next build",
    "start": "next start",
    "test:anchor": "yarn workspace @factorize/program-tests test",
    "generate:sdk": "cp target/idl/factorize.json lib/factorize/idl.json && cp target/idl/factorize.json supabase/functions/_shared/idl.json && npx codama run js && yarn workspace @factorize/sdk build",
    "postinstall": "yarn workspace @factorize/sdk build",
    "init:config": "tsx scripts/init-config.ts",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.36.0",
    "@codama/nodes-from-anchor": "^1.5.0",
    "@codama/renderers-js": "^2.2.0",
    "@codama/renderers-rust": "^3.1.0",
    "@coral-xyz/anchor": "^0.32.1",
    "@cosmjs/cosmwasm-stargate": "^0.38.1",
    "@cosmjs/launchpad": "^0.27.1",
    "@cosmjs/proto-signing": "^0.39.0",
    "@cosmjs/stargate": "^0.39.0",
    "@cosmjs/tendermint-rpc": "^0.39.0",
    "@factorize/sdk": "0.1.0",
    "@farcaster/mini-app-solana": "^2.0.0",
    "@farcaster/miniapp-sdk": "^0.3.0",
    "@farcaster/miniapp-wagmi-connector": "^2.0.0",
    "@getpara/react-sdk": "^3.1.0",
    "@leapwallet/cosmos-social-login-capsule-provider": "^0.0.44",
    "@solana-mobile/wallet-adapter-mobile": "^2.2.9",
    "@solana-program/system": "^0.12.2",
    "@solana-program/token": "^0.14.0",
    "@solana-program/token-2022": "^0.12.0",
    "@solana/kit": "6.9.0",
    "@solana/react": "6.9.0",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-walletconnect": "^0.1.21",
    "@solana/web3.js": "^1.98.4",
    "@stellar/stellar-sdk": "^15.1.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.101.0",
    "@wallet-standard/react": "^1.0.3",
    "clsx": "^2.1.1",
    "codama": "^1.7.0",
    "graz": "^0.4.2",
    "long": "^5.3.2",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "starknet": "^10.0.2",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "viem": "^2.52.2",
    "wagmi": "^2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bn.js": "^5.1.0",
    "@types/react": "^19.2.17",
    "@types/three": "^0.184.1",
    "postcss": "^8.5.15",
    "prettier": "^2.6.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
